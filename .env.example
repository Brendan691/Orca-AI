# ============================================================
# 小鲸 OrcaAI v0.2.0 环境变量
# 参照 OmniBox 模式，所有服务配置集中管理
# ============================================================

# ---- AI 服务 (通义千问) ----
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v3
CHAT_MODEL=qwen-max

# ---- 数据库 ----
DATABASE_URL=postgresql+asyncpg://orcaai:orcaai@localhost:5432/orcaai
DATABASE_URL_SYNC=postgresql://orcaai:orcaai@localhost:5432/orcaai

# ---- JWT 认证 ----
JWT_SECRET=change-me-to-a-random-secret-string
JWT_EXPIRE_MINUTES=43200

# ---- 文件存储 (MinIO / S3) ----
S3_ACCESS_KEY_ID=orcaaiadmin
S3_SECRET_ACCESS_KEY=orcaaiadmin
S3_ENDPOINT=localhost:9000
S3_BUCKET=orcaai-files
S3_SECURE=false

# ---- 全文搜索 (MeiliSearch) ----
MEILI_HOST=http://localhost:7700
MEILI_API_KEY=orcaai-meili-key

# ---- 联网搜索 (SearXNG) ----
SEARXNG_BASE_URL=http://localhost:8888

# ---- 微信 ----
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_TOKEN=
WECHAT_ENCODING_AES_KEY=

# ---- 应用 ----
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8501,chrome-extension://*

# ---- Chroma ----
CHROMA_PERSIST_DIR=./chroma_db

# ---- 日志 ----
LOG_LEVEL=INFO
LOG_JSON=false

# ---- 限流 ----
RATE_LIMIT_PER_MINUTE=60

# ---- 分块参数 ----
CHUNK_SIZE=1024
CHUNK_OVERLAP=128
TOP_K=5

# ---- 混合搜索权重 ----
VECTOR_WEIGHT=0.6
KEYWORD_WEIGHT=0.2
TIME_WEIGHT=0.1
TAG_WEIGHT=0.1
